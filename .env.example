# ══════════════════════════════════════════════════════════════
# MedNinja Passport — Environment Variables (TEMPLATE)
# ══════════════════════════════════════════════════════════════
#
# วิธีใช้ (dev local):
#   1. copy ไฟล์นี้เป็น .env  → cp .env.example .env
#   2. แก้ค่า xxx เป็นค่าจริง (ดูจาก .env ของ LMS ตัวจริงได้เลย เพราะใช้ค่าเดียวกัน)
#   3. เปลี่ยน PORT + FRONTEND_URL ให้ไม่ชนกับ LMS
#
# ⚠️  ค่าที่ต้อง "เหมือน LMS 100%" (เพราะทำงานคู่ขนาน DB เดียวกัน):
#     - MONGODB_URI, MONGODB_URI_LMS, MONGODB_URI_PASSPORT, MONGODB_URI_NLEX
#     - JWT_SECRET (token นักเรียนที่ login LMS อยู่ → เข้า passport ได้เลย)
#     - BUNNY_*
#     - LINE_*
#     - SMTP_*
#     - INTERNAL_API_KEY
#
# ⚠️  ค่าที่ต้อง "ต่างจาก LMS" (ห้ามชน):
#     - PORT (backend port)
#     - FRONTEND_URL (dev URL)

# ─── Database (DigitalOcean Managed MongoDB) ──────────────────
# ⚠️  ใช้ค่าเดียวกันกับ LMS — DB เดียวกัน 3 databases (lms, passport, nlex)
MONGODB_URI=xxx
MONGODB_URI_LMS=xxx
MONGODB_URI_PASSPORT=xxx
MONGODB_URI_NLEX=xxx

# ─── Valkey / Redis ───────────────────────────────────────────
REDIS_URL=xxx

# ─── JWT ──────────────────────────────────────────────────────
# ⚠️  ต้องเหมือน LMS — เพื่อ token ที่ออกจาก LMS ใช้กับ passport ได้เลย
JWT_SECRET=xxx

# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
# ⚠️  ต่างจาก LMS! (LMS = 3000, passport = 3100)
FRONTEND_URL=http://localhost:3100
# PORT=4100  # ถ้ามี — LMS ใช้ port อะไรก็ตั้ง passport ให้ต่าง

# ─── SMTP (Gmail Workspace) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@medninja.academy
SMTP_PASS=xxx

# ─── Bunny.net Video CDN ─────────────────────────────────────
BUNNY_LIBRARY_ID=xxx
BUNNY_CDN_HOSTNAME=xxx
BUNNY_SECURITY_KEY=xxx
BUNNY_API_KEY=xxx

BUNNY_DEMO_LIBRARY_ID=xxx
BUNNY_DEMO_API_KEY=xxx
BUNNY_DEMO_SECURITY_KEY=xxx

# ─── Bunny Storage (PDF) ─────────────────────────────────────
BUNNY_STORAGE_ZONE=medninja-docs
BUNNY_STORAGE_API_KEY=xxx
BUNNY_STORAGE_HOSTNAME=medninja-docs.b-cdn.net

# ─── AI / OCR (DigitalOcean Gradient AI) ─────────────────────
MODEL_ACCESS_KEY=xxx

# ─── LINE Messaging API ──────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=xxx

# ─── Beam Checkout ───────────────────────────────────────────
BEAM_MERCHANT_ID=xxx
BEAM_API_KEY=xxx
BEAM_API_URL=https://api.beamcheckout.com

# ─── LINE Webhook ────────────────────────────────────────────
LINE_MSG_CHANNEL_SECRET=xxx

# ─── LINE Login (LIFF) ───────────────────────────────────────
LINE_CHANNEL_ID=xxx
LINE_CHANNEL_SECRET=xxx

# ─── Partner API ─────────────────────────────────────────────
NLEX_API_KEY=xxx

# ─── ElevenLabs ──────────────────────────────────────────────
ELEVENLABS_API_KEY=xxx

# ─── Facebook ────────────────────────────────────────────────
FB_APP_ID=xxx
FB_APP_SECRET=xxx
FB_PAGE_ACCESS_TOKEN=xxx
